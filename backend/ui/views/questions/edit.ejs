<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Question</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <div class="container py-4" style="max-width: 920px;">
      <h1 class="mb-3">Edit Question</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="post" action="/questions/<%= data._id %>?_method=PUT" class="card card-body">
        <div class="mb-3">
          <label class="form-label">Question Text</label>
          <input class="form-control" name="questionText" required value="<%= data.question.questionText %>" />
        </div>

        <div id="options">
          <label class="form-label">Options (tick the correct one)</label>
          <% (data.question.options || []).forEach((opt, idx) => { %>
            <div class="input-group mb-2">
              <span class="input-group-text" style="min-width: 54px;"><%= String.fromCharCode(65 + idx) %></span>
              <div class="input-group-text">
                <input
                  class="form-check-input mt-0"
                  type="radio"
                  name="correctIndex"
                  value="<%= idx %>"
                  <%= opt === data.question.correctAnswer ? 'checked' : '' %>
                />
              </div>
              <input class="form-control" name="options" value="<%= opt %>" required />
            </div>
          <% }) %>
        </div>

        <div class="d-flex gap-2 mt-2">
          <button class="btn btn-outline-secondary" type="button" id="addOption">Add option</button>
        </div>

        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-primary" type="submit">Update</button>
          <a class="btn btn-outline-secondary" href="/questions/<%= data._id %>">Cancel</a>
        </div>
      </form>
    </div>

    <script>
      (function () {
        const optionsEl = document.getElementById('options');
        const addBtn = document.getElementById('addOption');

        function optionCount() {
          return optionsEl.querySelectorAll('input[name="options"]').length;
        }

        addBtn.addEventListener('click', () => {
          const idx = optionCount();
          const letter = String.fromCharCode(65 + idx);
          const wrapper = document.createElement('div');
          wrapper.className = 'input-group mb-2';
          wrapper.innerHTML = `
            <span class="input-group-text" style="min-width: 54px;">${letter}</span>
            <div class="input-group-text">
              <input class="form-check-input mt-0" type="radio" name="correctIndex" value="${idx}" />
            </div>
            <input class="form-control" name="options" required />
          `;
          optionsEl.appendChild(wrapper);
        });
      })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
