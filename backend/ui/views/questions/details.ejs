<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Question Details</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <div class="container py-4" style="max-width: 920px;">
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (!data) { %>
        <a class="btn btn-outline-secondary" href="/questions">Back</a>
      <% } else { %>
        <div class="d-flex align-items-start justify-content-between mb-3">
          <div>
            <h1 class="h3 mb-1"><%= data.question.questionText %></h1>
            <div class="text-muted">Quiz: <a href="/quizzes/<%= data.quizId %>"><%= data.quizTitle %></a></div>
          </div>
          <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/questions">Back</a>
            <% if (user && user.role === 'admin') { %>
              <a class="btn btn-warning" href="/questions/<%= data._id %>/edit">Edit</a>
              <form method="post" action="/questions/<%= data._id %>?_method=DELETE" class="mb-0">
                <button class="btn btn-danger" type="submit">Delete</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="card">
          <div class="card-body">
            <h2 class="h5">Options</h2>
            <ul class="list-group">
              <% (data.question.options || []).forEach((opt, idx) => { %>
                <li class="list-group-item d-flex align-items-center justify-content-between">
                  <span><strong><%= String.fromCharCode(65 + idx) %>.</strong> <%= opt %></span>
                  <% if (opt === data.question.correctAnswer) { %>
                    <span class="badge text-bg-success">Correct</span>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>
      <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
