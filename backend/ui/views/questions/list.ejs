<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Questions</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <div class="container py-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="mb-0">Questions</h1>
        <div class="d-flex gap-2">
          <a class="btn btn-outline-secondary" href="/quizzes">Quizzes</a>
          <% if (user && user.role === 'admin') { %>
            <a class="btn btn-primary" href="/questions/create">Create New Question(s)</a>
          <% } %>
          <form method="post" action="/logout" class="mb-0">
            <button class="btn btn-outline-secondary" type="submit">Logout</button>
          </form>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="list-group">
        <% questions.forEach(q => { %>
          <div class="list-group-item d-flex align-items-center justify-content-between">
            <div>
              <a href="/questions/<%= q._id %>"><%= q.questionText %></a>
              <div class="small text-muted">Quiz: <a href="/quizzes/<%= q.quizId %>"><%= q.quizTitle %></a></div>
            </div>
            <% if (user && user.role === 'admin') { %>
              <div class="d-flex gap-2">
                <a class="btn btn-sm btn-warning" href="/questions/<%= q._id %>/edit">Edit</a>
                <form method="post" action="/questions/<%= q._id %>?_method=DELETE" class="mb-0">
                  <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                </form>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
