<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quiz Details</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <div class="container py-4">
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (!quiz) { %>
        <a class="btn btn-outline-secondary" href="/quizzes">Back</a>
      <% } else { %>
        <div class="d-flex align-items-start justify-content-between mb-3">
          <div>
            <h1 class="mb-1"><%= quiz.title %></h1>
            <div class="text-muted"><%= quiz.description || '' %></div>
          </div>
          <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/quizzes">Back</a>
            <a class="btn btn-outline-secondary" href="/questions">All Questions</a>
            <% if (user && user.role === 'admin') { %>
              <a class="btn btn-primary" href="/quizzes/<%= quiz._id %>/questions/create">Add Questions</a>
              <a class="btn btn-warning" href="/quizzes/<%= quiz._id %>/edit">Edit Quiz</a>
              <form method="post" action="/quizzes/<%= quiz._id %>?_method=DELETE" class="mb-0">
                <button class="btn btn-danger" type="submit">Delete Quiz</button>
              </form>
            <% } %>
          </div>
        </div>

        <h2 class="h4 mt-4">Questions</h2>
        <div class="list-group">
          <% (quiz.questions || []).forEach(q => { %>
            <div class="list-group-item d-flex align-items-center justify-content-between">
              <a href="/questions/<%= q._id %>"><%= q.questionText %></a>
              <% if (user && user.role === 'admin') { %>
                <a class="btn btn-sm btn-warning" href="/questions/<%= q._id %>/edit">Edit</a>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
