<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Question Bank</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/style.css" rel="stylesheet" />
  </head>
  <body>
    <div class="container py-5">
      <h1 class="mb-3">Question Bank Management</h1>
      <p class="text-muted">UI dùng EJS (pages) + Handlebars (layout/partials).</p>
      <% if (user) { %>
        <a class="btn btn-primary" href="/quizzes">Go to Quizzes</a>
        <a class="btn btn-outline-secondary" href="/questions">Go to Questions</a>
      <% } else { %>
        <a class="btn btn-primary" href="/login">Login</a>
        <a class="btn btn-outline-secondary" href="/register">Register</a>
      <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
